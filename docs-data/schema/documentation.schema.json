{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/payment-docs/documentation.schema.json",
  "title": "Payment System Documentation Data",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "site", "actors", "apiCategories", "apis", "apiDetails", "sequenceGroups", "sequences", "database", "notificationTemplateCatalog", "deploymentOperationsGuide", "systemArchitecture", "policies"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Documentation data schema version, for example 1.0.0."
    },
    "site": {
      "$ref": "#/$defs/site"
    },
    "actors": {
      "type": "array",
      "description": "Reusable participants in sequence diagrams.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/actor"
      },
      "uniqueItems": true
    },
    "apiCategories": {
      "type": "array",
      "description": "Groups used in the full API catalog page.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/apiCategory"
      }
    },
    "apis": {
      "type": "array",
      "description": "Single catalog of every API. Sequence documents reference these by id.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/api"
      }
    },
    "apiDetails": {
      "type": "object",
      "description": "Detailed API contracts keyed by api id. This is the single source of truth for headers, cookies, body, response, and logic.",
      "additionalProperties": {
        "$ref": "#/$defs/apiDetail"
      }
    },
    "sequenceGroups": {
      "type": "array",
      "description": "Topic groups used in the sequence index page.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sequenceGroup"
      }
    },
    "sequences": {
      "type": "array",
      "description": "Sequence diagram pages. Available pages can render diagrams; planned pages can appear only in the sequence index.",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/sequencePage"
      }
    },
    "risks": {
      "type": "array",
      "description": "Potential payment risks and the handling strategy for each risk.",
      "items": {
        "$ref": "#/$defs/risk"
      }
    },
    "policies": {
      "$ref": "#/$defs/policies"
    },
    "database": {
      "$ref": "#/$defs/database"
    },
    "notificationTemplateCatalog": {
      "$ref": "#/$defs/notificationTemplateCatalog"
    },
    "deploymentOperationsGuide": {
      "$ref": "#/$defs/deploymentOperationsGuide"
    },
    "deploymentOperationsGuide": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "audience", "scope", "runtimeTopology", "configuration", "deploymentProcedure", "preDeploymentChecklist", "postDeploymentVerification", "observability", "runbooks", "rollbackAndReplayPolicy", "securityAndAccessControl", "relatedDocuments"],
      "properties": {
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "audience": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "scope": {
          "$ref": "#/$defs/deploymentScope"
        },
        "runtimeTopology": {
          "$ref": "#/$defs/deploymentRuntimeTopology"
        },
        "configuration": {
          "$ref": "#/$defs/deploymentConfiguration"
        },
        "deploymentProcedure": {
          "$ref": "#/$defs/deploymentProcedure"
        },
        "preDeploymentChecklist": {
          "$ref": "#/$defs/stringList"
        },
        "postDeploymentVerification": {
          "$ref": "#/$defs/stringList"
        },
        "observability": {
          "$ref": "#/$defs/deploymentObservability"
        },
        "runbooks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/deploymentRunbook"
          }
        },
        "rollbackAndReplayPolicy": {
          "$ref": "#/$defs/titledRules"
        },
        "securityAndAccessControl": {
          "$ref": "#/$defs/titledRules"
        },
        "relatedDocuments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/relatedDocument"
          }
        }
      }
    },
    "deploymentScope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["included", "excluded"],
      "properties": {
        "included": {
          "$ref": "#/$defs/stringList"
        },
        "excluded": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "deploymentRuntimeTopology": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "components"],
      "properties": {
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/runtimeComponent"
          }
        }
      }
    },
    "runtimeComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "workload", "entrypoint", "responsibility", "operationalNotes"],
      "properties": {
        "name": {
          "type": "string"
        },
        "workload": {
          "type": "string"
        },
        "entrypoint": {
          "type": "string"
        },
        "responsibility": {
          "type": "string"
        },
        "operationalNotes": {
          "type": "string"
        }
      }
    },
    "deploymentConfiguration": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "groups", "rules"],
      "properties": {
        "title": {
          "type": "string"
        },
        "groups": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/configurationGroup"
          }
        },
        "rules": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "configurationGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "appliesTo", "settings"],
      "properties": {
        "name": {
          "type": "string"
        },
        "appliesTo": {
          "type": "string"
        },
        "settings": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/configurationSetting"
          }
        }
      }
    },
    "configurationSetting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "required", "default", "secret", "description"],
      "properties": {
        "name": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "default": {
          "type": "string"
        },
        "secret": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "deploymentProcedure": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "steps"],
      "properties": {
        "title": {
          "type": "string"
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/deploymentStep"
          }
        }
      }
    },
    "deploymentStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "command", "description", "verification"],
      "properties": {
        "title": {
          "type": "string"
        },
        "command": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "verification": {
          "type": "string"
        }
      }
    },
    "deploymentObservability": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "collections", "logs"],
      "properties": {
        "title": {
          "type": "string"
        },
        "collections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/observabilityCollection"
          }
        },
        "logs": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/observabilityLog"
          }
        }
      }
    },
    "observabilityCollection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "purpose", "healthySignal", "alertCondition"],
      "properties": {
        "name": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "healthySignal": {
          "type": "string"
        },
        "alertCondition": {
          "type": "string"
        }
      }
    },
    "observabilityLog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "purpose", "notes"],
      "properties": {
        "name": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "deploymentRunbook": {
      "type": "object",
      "additionalProperties": false,
      "required": ["incident", "symptoms", "checks", "actions", "doNot"],
      "properties": {
        "incident": {
          "type": "string"
        },
        "symptoms": {
          "$ref": "#/$defs/stringList"
        },
        "checks": {
          "$ref": "#/$defs/stringList"
        },
        "actions": {
          "$ref": "#/$defs/stringList"
        },
        "doNot": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "titledRules": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "rules"],
      "properties": {
        "title": {
          "type": "string"
        },
        "rules": {
          "$ref": "#/$defs/stringList"
        }
      }
    },
    "relatedDocument": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "pageKey", "anchor", "description"],
      "properties": {
        "title": {
          "type": "string"
        },
        "pageKey": {
          "type": "string"
        },
        "anchor": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "stringList": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "systemArchitecture": {
      "$ref": "#/$defs/systemArchitecture"
    }
  },
  "$defs": {
    "site": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "pages"],
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "pages": {
          "type": "object",
          "additionalProperties": false,
          "required": ["sequenceIndex", "apiCatalog", "apiDetails", "notificationTemplateCatalog", "deploymentOperationsGuide"],
          "properties": {
            "sequenceIndex": {
              "$ref": "#/$defs/pageRef"
            },
            "apiCatalog": {
              "$ref": "#/$defs/pageRef"
            },
            "apiDetails": {
              "$ref": "#/$defs/pageRef"
            },
            "database": {
              "$ref": "#/$defs/pageRef"
            },
            "risks": {
              "$ref": "#/$defs/pageRef"
            },
            "systemArchitecture": {
              "$ref": "#/$defs/pageRef"
            },
            "deploymentOperationsGuide": {
              "$ref": "#/$defs/pageRef"
            },
            "notificationTemplateCatalog": {
              "$ref": "#/$defs/pageRef"
            }
          }
        }
      }
    },
    "pageRef": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "file"],
      "properties": {
        "title": {
          "type": "string"
        },
        "file": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._/-]+\\.html$"
        }
      }
    },
    "actor": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "subtitle", "kind"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "type": "string"
        },
        "subtitle": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": ["client", "server", "provider", "scheduler", "admin", "system"]
        },
        "theme": {
          "type": "string",
          "enum": ["client", "server", "toss", "scheduler", "admin", "danger", "neutral"]
        }
      }
    },
    "apiCategory": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "order"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "api": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "categoryId", "method", "path", "role", "detailStatus"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "categoryId": {
          "$ref": "#/$defs/id"
        },
        "method": {
          "$ref": "#/$defs/httpMethod"
        },
        "path": {
          "type": "string",
          "pattern": "^/[A-Za-z0-9{}._~:/-]+$"
        },
        "role": {
          "type": "string",
          "description": "One sentence describing what this API does."
        },
        "visibility": {
          "type": "string",
          "description": "End-user access level shown in the API catalog. It is not the transport authentication between the backend server/BFF and the payment system; public APIs can still require an internal service Authorization header.",
          "enum": ["public", "authenticated", "webhook", "internal", "admin", "admin-auth"],
          "default": "authenticated"
        },
        "detailStatus": {
          "type": "string",
          "enum": ["available", "planned"]
        },
        "detailAnchor": {
          "type": "string",
          "description": "Anchor id in the API detail page when detailStatus is available."
        },
        "tags": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "uniqueItems": true
        }
      }
    },
    "apiDetail": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "request", "responses", "logic"],
      "properties": {
        "summary": {
          "type": "string"
        },
        "redirectNote": {
          "type": "string",
          "description": "Use for APIs such as subscription confirm that are called by the frontend success page, not directly by Toss redirect."
        },
        "request": {
          "$ref": "#/$defs/requestContract"
        },
        "frontendInputs": {
          "type": "array",
          "description": "Values collected by a frontend page before calling this API.",
          "items": {
            "$ref": "#/$defs/sourceField"
          }
        },
        "responses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/responseContract"
          }
        },
        "logic": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "failureRules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/failureRule"
          }
        },
        "externalCalls": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/externalCall"
          }
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "riskIds": {
          "$ref": "#/$defs/riskIds"
        }
      }
    },
    "sequenceGroup": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "order"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string"
        },
        "order": {
          "type": "integer",
          "minimum": 1
        },
        "description": {
          "type": "string"
        }
      }
    },
    "requestContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["headers", "cookies"],
      "properties": {
        "headers": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "cookies": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "bodyFields": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/field"
          }
        },
        "bodyExample": {
          "$ref": "#/$defs/jsonValue"
        }
      }
    },
    "responseContract": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "description"],
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "description": {
          "type": "string"
        },
        "bodyExample": {
          "$ref": "#/$defs/jsonValue"
        }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "required", "description"],
      "properties": {
        "name": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "example": {
          "$ref": "#/$defs/jsonValue"
        }
      }
    },
    "database": {
      "type": "object",
      "additionalProperties": false,
      "required": ["engine", "collections"],
      "properties": {
        "engine": {
          "type": "string",
          "enum": ["MongoDB"]
        },
        "description": {
          "type": "string"
        },
        "collections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dbCollection"
          }
        },
        "relationships": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dbRelationship"
          }
        },
        "apiAccess": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dbApiAccess"
          }
        },
        "stateModels": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dbStateModel"
          }
        }
      }
    },
    "dbCollection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "title", "description", "fields"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "name": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/dbField"
          }
        },
        "indexes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dbIndex"
          }
        },
        "relatedApis": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "riskIds": {
          "$ref": "#/$defs/riskIds"
        }
      }
    },
    "dbField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "required", "description"],
      "properties": {
        "name": {
          "type": "string"
        },
        "type": {
          "type": "string"
        },
        "required": {
          "type": "boolean"
        },
        "description": {
          "type": "string"
        },
        "ref": {
          "type": "string"
        },
        "enum": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "example": {
          "$ref": "#/$defs/jsonValue"
        },
        "properties": {
          "type": "array",
          "description": "Nested field contract for object fields.",
          "items": {
            "$ref": "#/$defs/dbField"
          }
        },
        "items": {
          "type": "object",
          "description": "Nested item contract for array<object> fields.",
          "additionalProperties": false,
          "required": ["properties"],
          "properties": {
            "properties": {
              "type": "array",
              "items": {
                "$ref": "#/$defs/dbField"
              }
            }
          }
        }
      }
    },
    "dbIndex": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fields"],
      "properties": {
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "name": {
          "type": "string"
        },
        "unique": {
          "type": "boolean"
        },
        "sparse": {
          "type": "boolean"
        },
        "partialFilterExpression": {
          "$ref": "#/$defs/jsonValue"
        },
        "expireAfterSeconds": {
          "type": "integer",
          "minimum": 0
        },
        "description": {
          "type": "string"
        }
      }
    },
    "dbRelationship": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "type", "description"],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["reference", "embedded", "snapshot"]
        },
        "description": {
          "type": "string"
        }
      }
    },
    "dbApiAccess": {
      "type": "object",
      "additionalProperties": false,
      "required": ["apiId", "reads", "writes", "description"],
      "properties": {
        "apiId": {
          "$ref": "#/$defs/id"
        },
        "reads": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "writes": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "description": {
          "type": "string"
        }
      }
    },
    "dbStateModel": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "collection", "field", "states", "transitions"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string"
        },
        "collection": {
          "$ref": "#/$defs/id"
        },
        "field": {
          "type": "string"
        },
        "states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/dbStateTransition"
          }
        }
      }
    },
    "dbStateTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "event"],
      "properties": {
        "from": {
          "type": "string"
        },
        "to": {
          "type": "string"
        },
        "event": {
          "type": "string"
        }
      }
    },
    "sourceField": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "source", "description"],
      "properties": {
        "name": {
          "type": "string"
        },
        "source": {
          "type": "string",
          "enum": ["redirectQuery", "sessionStorage", "routeState", "serverResponse", "generatedByFrontend", "cookie", "header"]
        },
        "description": {
          "type": "string"
        }
      }
    },
    "failureRule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "httpStatus", "description", "retryable"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z0-9_]+$"
        },
        "httpStatus": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "description": {
          "type": "string"
        },
        "retryable": {
          "type": "boolean"
        },
        "resultState": {
          "type": "string"
        }
      }
    },
    "externalCall": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "method", "path", "purpose"],
      "properties": {
        "provider": {
          "type": "string",
          "enum": ["tosspayments"]
        },
        "method": {
          "$ref": "#/$defs/httpMethod"
        },
        "path": {
          "type": "string"
        },
        "purpose": {
          "type": "string"
        }
      }
    },
    "sequencePage": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "file", "status", "kind", "groupId", "summary", "apiIds"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string"
        },
        "file": {
          "type": "string",
          "pattern": "^[A-Za-z0-9._/-]+\\.html$"
        },
        "status": {
          "type": "string",
          "enum": ["available", "planned"]
        },
        "kind": {
          "type": "string",
          "enum": ["success", "failure", "operation", "payment", "admin"]
        },
        "groupId": {
          "$ref": "#/$defs/id"
        },
        "summary": {
          "type": "string"
        },
        "apiIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "actorIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "diagrams": {
          "type": "array",
          "description": "Available sequence pages render one or more diagrams. Failure pages usually have multiple diagrams.",
          "items": {
            "$ref": "#/$defs/diagram"
          }
        },
        "riskIds": {
          "$ref": "#/$defs/riskIds"
        }
      }
    },
    "riskIds": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/id"
      },
      "uniqueItems": true
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "severity", "category", "summary", "trigger", "impact", "handling", "prevention"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["critical", "high", "medium", "low"]
        },
        "category": {
          "type": "string",
          "enum": ["failure", "retry", "ordering", "concurrency", "data-integrity", "security", "operations"]
        },
        "summary": {
          "type": "string"
        },
        "trigger": {
          "type": "string"
        },
        "impact": {
          "type": "string"
        },
        "detection": {
          "type": "string"
        },
        "handling": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "prevention": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "relatedApis": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "relatedSequences": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "relatedCollections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        }
      }
    },
    "diagram": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "actorIds", "steps"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "actorIds": {
          "type": "array",
          "minItems": 2,
          "items": {
            "$ref": "#/$defs/id"
          }
        },
        "relatedApiIds": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/id"
          },
          "uniqueItems": true
        },
        "steps": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sequenceStep"
          }
        },
        "stateSummary": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/stateTransition"
          }
        }
      }
    },
    "sequenceStep": {
      "type": "object",
      "additionalProperties": false,
      "required": ["type", "label"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["message", "self", "callout", "branch"]
        },
        "from": {
          "$ref": "#/$defs/id"
        },
        "to": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "type": "string"
        },
        "apiId": {
          "$ref": "#/$defs/id"
        },
        "externalCall": {
          "$ref": "#/$defs/externalCall"
        },
        "code": {
          "type": "string"
        },
        "note": {
          "type": "string"
        },
        "theme": {
          "type": "string",
          "enum": ["client", "server", "toss", "success", "failure", "neutral"]
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "message"
              }
            }
          },
          "then": {
            "required": ["from", "to"]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "self"
              }
            }
          },
          "then": {
            "required": ["from"]
          }
        }
      ]
    },
    "stateTransition": {
      "type": "object",
      "additionalProperties": false,
      "required": ["event", "subscriptionState", "paymentState", "description"],
      "properties": {
        "event": {
          "type": "string"
        },
        "subscriptionState": {
          "type": "string"
        },
        "paymentState": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "frontendAction": {
          "type": "string"
        }
      }
    },
    "policies": {
      "type": "object",
      "additionalProperties": false,
      "required": ["idempotency", "httpStatus", "security", "tosspayments"],
      "properties": {
        "idempotency": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "httpStatus": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/httpStatusPolicy"
          }
        },
        "security": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "tosspayments": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "notificationTemplateCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "commonOptionalArgs", "rules", "encryptedValueObject", "idempotencyKeyPolicy", "renderingPolicy", "seedPolicy", "fallbackPolicy", "templates"],
      "properties": {
        "title": {
          "type": "string"
