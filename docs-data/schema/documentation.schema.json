          "items": {
            "type": "string"
          }
        },
        "retryableFailures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "permanentFailures": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "notificationWorkerSetting": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "value", "description"],
