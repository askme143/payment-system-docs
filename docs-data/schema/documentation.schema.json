        },
        "recipientType": {
          "type": "string",
          "enum": ["user", "admin", "external"]
        },
        "requiredTemplateArgs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optionalTemplateArgs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "encryptedArgs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "systemArchitecture": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary", "diagrams", "components", "dataStores", "workerPolicy", "operations"],
      "properties": {
        "title": {
          "type": "string"
        },
        "summary": {
          "type": "string"
        },
        "diagrams": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/architectureDiagram"
          }
        },
        "components": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/architectureComponent"
          }
        },
        "dataStores": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/architectureDataStore"
          }
        },
        "adminConsoleRoutes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/adminConsoleRoute"
          }
        },
        "workerPolicy": {
          "$ref": "#/$defs/notificationWorkerPolicy"
        },
        "operations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/architectureOperation"
          }
        }
      }
    },
    "architectureDiagram": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "title", "nodes", "edges"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        },
        "nodes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/architectureNode"
          }
        },
        "edges": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/architectureEdge"
          }
        }
      }
    },
    "architectureNode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "kind", "description"],
      "properties": {
        "id": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "type": "string"
        },
        "kind": {
          "type": "string",
          "enum": ["client", "server", "scheduler", "database", "queue", "worker", "provider", "external", "success", "failure"]
        },
        "description": {
          "type": "string"
        }
      }
    },
    "architectureEdge": {
      "type": "object",
      "additionalProperties": false,
      "required": ["from", "to", "label"],
      "properties": {
        "from": {
          "$ref": "#/$defs/id"
        },
        "to": {
          "$ref": "#/$defs/id"
        },
        "label": {
          "type": "string"
        }
      }
    },
    "architectureComponent": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "responsibility", "failurePolicy"],
      "properties": {
        "name": {
          "type": "string"
        },
        "responsibility": {
          "type": "string"
        },
        "failurePolicy": {
          "type": "string"
        }
      }
    },
    "architectureDataStore": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "owner", "keys", "notes"],
      "properties": {
        "name": {
          "type": "string"
        },
        "owner": {
          "type": "string"
        },
        "keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "adminConsoleRoute": {
      "type": "object",
      "additionalProperties": false,
      "required": ["path", "page", "primaryApis", "purpose", "mvp"],
      "properties": {
        "path": {
          "type": "string"
        },
        "page": {
          "type": "string"
        },
        "primaryApis": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "purpose": {
          "type": "string"
        },
        "mvp": {
          "type": "boolean"
        }
      }
    },
    "architectureOperation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "description"],
      "properties": {
        "title": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      }
    },
    "httpStatusPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "usage"],
      "properties": {
        "status": {
          "type": "integer",
          "minimum": 100,
          "maximum": 599
        },
        "usage": {
          "type": "string"
        }
      }
    },
    "httpMethod": {
      "type": "string",
      "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]
    },
    "id": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9-]*$"
    },
    "jsonValue": {
      "description": "Any JSON value.",
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "boolean"
        },
        {
          "type": "number"
        },
        {
          "type": "string"
        },
        {
          "type": "array",
          "items": {
            "$ref": "#/$defs/jsonValue"
          }
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/jsonValue"
          }
        }
      ]
    }
  }
}
