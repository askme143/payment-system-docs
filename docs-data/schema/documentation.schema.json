        "idempotencyKeyPolicy": {
          "$ref": "#/$defs/notificationIdempotencyKeyPolicy"
        },
        "renderingPolicy": {
          "$ref": "#/$defs/notificationRenderingPolicy"
        },
        "seedPolicy": {
          "$ref": "#/$defs/notificationSeedPolicy"
