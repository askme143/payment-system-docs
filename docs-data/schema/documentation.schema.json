          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    },
    "notificationEncryptedValueObject": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "appliesTo", "description", "failurePolicy", "example", "fields"],
